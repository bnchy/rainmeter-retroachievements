[Rainmeter]
; Each tick can complete one download per pool slot (6), so this rate
; and DL_SLOTS together set how fast badge art fills in. 500ms keeps
; idle CPU negligible while still filling a row in well under a second.
Update=500
AccurateText=1
DynamicWindowSize=1
@IncludeVariables=#@#Variables.inc

[Metadata]
Name=RetroAchievements
Information=Recent RetroAchievements unlocks as a card grid on an iOS-style glass background. First run: click the setup lines to enter your username and Web API key (retroachievements.org -> Settings -> Keys).
Version=2.1

; content sits on a 16px (x) / 14px (y) padding inside the glass card

; =================================================================
; MEASURES
; =================================================================

; One-shot boot trigger: 2s after load, force a fresh fetch.
; WebParser keeps a per-URL update window across refreshes, so without
; this a refreshed skin can silently wait out the full UpdateRate.
[MeasureBoot]
Measure=Calc
Formula=Counter
IfCondition=MeasureBoot >= 2
IfTrueAction=[!CommandMeasure MeasureRecent "Update"][!CommandMeasure MeasureProfile "Update"][!CommandMeasure MeasureRank "Update"][!DisableMeasure MeasureBoot]

; Decides between setup mode (missing credentials) and normal mode
[MeasureSetup]
Measure=String
String=#UserName#|#APIKey#
UpdateDivider=-1
IfMatch=^\||\|$
IfMatchAction=[!ShowMeterGroup Setup][!HideMeterGroup Main][!Redraw]
IfNotMatchAction=[!ShowMeterGroup Main][!HideMeterGroup Setup][!Redraw]

; The N most recently played games - count-based, no date window
[MeasureRecent]
Measure=WebParser
ForceReload=1
Url=https://retroachievements.org/API/API_GetUserRecentlyPlayedGames.php?u=#UserName#&y=#APIKey#&c=#MaxGames#
RegExp=(?s)^(.*)$
StringIndex=1
UpdateRate=#UpdateRate#
CodePage=65001
FinishAction=[!CommandMeasure MeasureScript "Parse()"]
OnConnectErrorAction=[!Log "RA: game list fetch failed (connection)" Error]
OnRegExpErrorAction=[!Log "RA: game list fetch failed (regexp)" Error]

[MeasureProfile]
Measure=WebParser
ForceReload=1
Url=https://retroachievements.org/API/API_GetUserProfile.php?u=#UserName#&y=#APIKey#
; whole body, parsed in Lua - a single regex over a field whose text
; changes as you play is fragile, and every other call here does the same
RegExp=(?s)^(.*)$
StringIndex=1
UpdateRate=#UpdateRate#
CodePage=65001
FinishAction=[!CommandMeasure MeasureScript "ProfileDone()"]

; -- RA site rank -------------------------------------------------

[MeasureRank]
Measure=WebParser
ForceReload=1
Url=https://retroachievements.org/API/API_GetUserRankAndScore.php?u=#UserName#&y=#APIKey#
RegExp=(?s)^(.*)$
StringIndex=1
UpdateRate=#UpdateRate#
CodePage=65001
FinishAction=[!CommandMeasure MeasureScript "RankDone()"]

; -- badge downloader: a pool of parallel slots ---------------------
; A WebParser download completes on the skin's update tick, so a single
; serial slot costs ~1s per badge no matter how small it is. Running a
; few in parallel cuts that proportionally while staying polite to the
; CDN. Urls are assigned per download by RA.lua; files persist in
; DownloadFile\ so each badge is only ever fetched once.

[MeasureIconDL1]
Measure=WebParser
ForceReload=1
Url=
Download=1
UpdateRate=1000000
Disabled=1
FinishAction=[!CommandMeasure MeasureScript "IconDone(1)"]
OnDownloadErrorAction=[!CommandMeasure MeasureScript "IconFail(1)"]
OnConnectErrorAction=[!CommandMeasure MeasureScript "IconFail(1)"]

[MeasureIconDL2]
Measure=WebParser
ForceReload=1
Url=
Download=1
UpdateRate=1000000
Disabled=1
FinishAction=[!CommandMeasure MeasureScript "IconDone(2)"]
OnDownloadErrorAction=[!CommandMeasure MeasureScript "IconFail(2)"]
OnConnectErrorAction=[!CommandMeasure MeasureScript "IconFail(2)"]

[MeasureIconDL3]
Measure=WebParser
ForceReload=1
Url=
Download=1
UpdateRate=1000000
Disabled=1
FinishAction=[!CommandMeasure MeasureScript "IconDone(3)"]
OnDownloadErrorAction=[!CommandMeasure MeasureScript "IconFail(3)"]
OnConnectErrorAction=[!CommandMeasure MeasureScript "IconFail(3)"]

[MeasureIconDL4]
Measure=WebParser
ForceReload=1
Url=
Download=1
UpdateRate=1000000
Disabled=1
FinishAction=[!CommandMeasure MeasureScript "IconDone(4)"]
OnDownloadErrorAction=[!CommandMeasure MeasureScript "IconFail(4)"]
OnConnectErrorAction=[!CommandMeasure MeasureScript "IconFail(4)"]

[MeasureIconDL5]
Measure=WebParser
ForceReload=1
Url=
Download=1
UpdateRate=1000000
Disabled=1
FinishAction=[!CommandMeasure MeasureScript "IconDone(5)"]
OnDownloadErrorAction=[!CommandMeasure MeasureScript "IconFail(5)"]
OnConnectErrorAction=[!CommandMeasure MeasureScript "IconFail(5)"]

[MeasureIconDL6]
Measure=WebParser
ForceReload=1
Url=
Download=1
UpdateRate=1000000
Disabled=1
FinishAction=[!CommandMeasure MeasureScript "IconDone(6)"]
OnDownloadErrorAction=[!CommandMeasure MeasureScript "IconFail(6)"]
OnConnectErrorAction=[!CommandMeasure MeasureScript "IconFail(6)"]

; -- per-game detail: full unlock history, progress and playtime.
; One measure per displayed game; Urls are set by RA.lua.

[MeasureGame1]
Measure=WebParser
ForceReload=1
Url=
RegExp=(?s)^(.*)$
StringIndex=1
CodePage=65001
UpdateRate=1000000
FinishAction=[!CommandMeasure MeasureScript "GameDone(1)"]
OnConnectErrorAction=[!CommandMeasure MeasureScript "GameFail(1)"]
OnRegExpErrorAction=[!CommandMeasure MeasureScript "GameFail(1)"]

[MeasureGame2]
Measure=WebParser
ForceReload=1
Url=
RegExp=(?s)^(.*)$
StringIndex=1
CodePage=65001
UpdateRate=1000000
FinishAction=[!CommandMeasure MeasureScript "GameDone(2)"]
OnConnectErrorAction=[!CommandMeasure MeasureScript "GameFail(2)"]
OnRegExpErrorAction=[!CommandMeasure MeasureScript "GameFail(2)"]

[MeasureGame3]
Measure=WebParser
ForceReload=1
Url=
RegExp=(?s)^(.*)$
StringIndex=1
CodePage=65001
UpdateRate=1000000
FinishAction=[!CommandMeasure MeasureScript "GameDone(3)"]
OnConnectErrorAction=[!CommandMeasure MeasureScript "GameFail(3)"]
OnRegExpErrorAction=[!CommandMeasure MeasureScript "GameFail(3)"]

[MeasureGame4]
Measure=WebParser
ForceReload=1
Url=
RegExp=(?s)^(.*)$
StringIndex=1
CodePage=65001
UpdateRate=1000000
FinishAction=[!CommandMeasure MeasureScript "GameDone(4)"]
OnConnectErrorAction=[!CommandMeasure MeasureScript "GameFail(4)"]
OnRegExpErrorAction=[!CommandMeasure MeasureScript "GameFail(4)"]

[MeasureScript]
Measure=Script
ScriptFile=#@#Scripts\RA.lua
UpdateDivider=-1

; -- input fields for first-run setup -----------------------------

[InputUser]
Measure=Plugin
Plugin=InputText
X=136
Y=52
W=220
H=18
SolidColor=30,30,30,240
FontColor=#TextColor#
FontFace=#BodyFont#
FontSize=10
FocusDismiss=1
DefaultValue=""
Command1=[!WriteKeyValue Variables UserName "$UserInput$" "#@#Variables.inc"][!Refresh]

[InputKey]
Measure=Plugin
Plugin=InputText
X=136
Y=78
W=250
H=18
SolidColor=30,30,30,240
FontColor=#TextColor#
FontFace=#BodyFont#
FontSize=10
Password=1
FocusDismiss=1
DefaultValue=""
Command1=[!WriteKeyValue Variables APIKey "$UserInput$" "#@#Variables.inc"][!Refresh]

; =================================================================
; STYLES
; =================================================================

[StyleText]
FontFace=#BodyFont#
FontColor=#TextColor#
FontSize=10
AntiAlias=1
Group=Main
Hidden=1

[StyleDim]
FontFace=#BodyFont#
FontColor=#DimColor#
FontSize=8
AntiAlias=1
Group=Main
Hidden=1

[StyleHeadTitle]
FontFace=#BodyFont#
FontColor=#TextColor#
FontSize=9
AntiAlias=1
SolidColor=0,0,0,1
Group=Main
Hidden=1

[StyleHeadStats]
FontFace=#BodyFont#
FontColor=#DimColor#
FontSize=9
AntiAlias=1
Group=Main
Hidden=1

[StyleHeadPts]
FontFace=#BodyFont#
FontColor=#AccentColor#
FontSize=9
AntiAlias=1
StringAlign=Right
Group=Main
Hidden=1

[StyleBadge]
W=48
H=48
PreserveAspectRatio=1
Group=Main
Hidden=1

[StyleHeadPos]
FontFace=#BodyFont#
FontColor=#DimColor#
FontSize=8
AntiAlias=1
StringAlign=Right
SolidColor=0,0,0,1
Group=Main
Hidden=1

[StyleSetup]
FontFace=#BodyFont#
FontColor=#TextColor#
FontSize=10
AntiAlias=1
Group=Setup
Hidden=1

; =================================================================
; METERS - BACKGROUND (always visible)
; =================================================================

[MeterBackground]
Meter=Shape
X=0
Y=0
; height grows with the number of game groups shown
Shape=Rectangle 0,0,(#SkinWidth#+32),(76+82*#MaxGames#),#BgRadius# | Fill Color #BgColor# | StrokeWidth 1 | Stroke Color #BgStroke#

; =================================================================
; METERS - SETUP MODE
; =================================================================

[MeterSetupTitle]
Meter=String
MeterStyle=StyleSetup
FontFace=#HeaderFont#
FontColor=#AccentColor#
FontSize=13
X=16
Y=14
Text=RETROACHIEVEMENTS

[MeterSetupUser]
Meter=String
MeterStyle=StyleSetup
X=16
Y=54
Text=USERNAME  -  click to type
LeftMouseUpAction=[!CommandMeasure InputUser "ExecuteBatch 1"]

[MeterSetupUserVal]
Meter=String
MeterStyle=StyleSetup
FontColor=#AccentColor#
X=236
Y=54
Text=#UserName#
DynamicVariables=1

[MeterSetupKey]
Meter=String
MeterStyle=StyleSetup
X=16
Y=80
Text=WEB API KEY  -  click to type
LeftMouseUpAction=[!CommandMeasure InputKey "ExecuteBatch 1"]

[MeterSetupHint]
Meter=String
MeterStyle=StyleSetup
FontColor=#DimColor#
FontSize=8
X=16
Y=112
Text=Get your key at retroachievements.org -> Settings -> Keys  (click to open)
LeftMouseUpAction=["https://retroachievements.org/settings"]

; =================================================================
; METERS - MAIN MODE
; =================================================================

; -- header: username left, scores right --------------------------

[MeterName]
Meter=String
MeterStyle=StyleText
FontFace=#HeaderFont#
FontSize=13
StringCase=Upper
X=16
Y=14
Text=#UserName#
DynamicVariables=1
LeftMouseUpAction=["https://retroachievements.org/user/#UserName#"]

[MeterPoints]
Meter=String
MeterStyle=StyleText
StringAlign=Right
X=(#SkinWidth#+16)
Y=17
Text=... PTS
LeftMouseUpAction=["https://retroachievements.org/user/#UserName#"]

; -- live rich presence (left) + site rank (right) ----------------

[MeterPresence]
Meter=String
MeterStyle=StyleDim
X=16
Y=35
W=(#SkinWidth#-140)
H=12
ClipString=1
Text=

[MeterRank]
Meter=String
MeterStyle=StyleDim
StringAlign=Right
X=(#SkinWidth#+16)
Y=35
Text=
LeftMouseUpAction=["https://retroachievements.org/user/#UserName#"]

; -- order by control ---------------------------------------------

[MeterOrderLabel]
Meter=String
MeterStyle=StyleDim
X=16
Y=50
Text=ORDER BY :

[MeterOrderValue]
Meter=String
MeterStyle=StyleDim
FontColor=#AccentColor#
X=78
Y=50
Text=DATE
SolidColor=0,0,0,1
LeftMouseUpAction=[!CommandMeasure MeasureScript "CycleSort()"]
ToolTipText=Click to cycle: date / points / game

[MeterOrderDir]
Meter=String
MeterStyle=StyleDim
FontColor=#AccentColor#
X=126
Y=50
Text=v
SolidColor=0,0,0,1
Padding=4,0,4,0
LeftMouseUpAction=[!CommandMeasure MeasureScript "ToggleDir()"]
ToolTipText=Click to flip direction

; padlock icons: a stroked ring whose lower half is hidden behind the
; body, so the shackle sits centred (closed) or off to one side (open)

[MeterLockOpen]
Meter=Shape
X=166
Y=47
Shape=Ellipse 11,5.5,3.5,3.5 | StrokeWidth 1.6 | Stroke Color #AccentColor# | Fill Color 0,0,0,0
Shape2=Rectangle 1,7,13,7,2 | Fill Color #AccentColor# | StrokeWidth 0
Group=Main
Hidden=1
LeftMouseUpAction=[!CommandMeasure MeasureScript "ToggleFilter()"]
ToolTipText=Showing achievements you have earned - click for the ones still locked

[MeterLockClosed]
Meter=Shape
X=166
Y=47
Shape=Ellipse 7.5,5.5,3.5,3.5 | StrokeWidth 1.6 | Stroke Color #AccentColor# | Fill Color 0,0,0,0
Shape2=Rectangle 1,7,13,7,2 | Fill Color #AccentColor# | StrokeWidth 0
Group=Main
Hidden=1
LeftMouseUpAction=[!CommandMeasure MeasureScript "ToggleFilter()"]
ToolTipText=Showing achievements still locked - click for the ones you have earned

[MeterFilter]
Meter=String
MeterStyle=StyleDim
FontColor=#AccentColor#
X=186
Y=50
Text=UNLOCKED
SolidColor=0,0,0,1
LeftMouseUpAction=[!CommandMeasure MeasureScript "ToggleFilter()"]
ToolTipText=Click to switch between achievements you have earned and the ones still locked

; -- refresh / edit -----------------------------------------------

[MeterRefresh]
Meter=String
MeterStyle=StyleDim
StringAlign=Right
X=(#SkinWidth#+16)
Y=50
Text=REFRESH
LeftMouseUpAction=[!CommandMeasure MeasureRecent "Update"][!CommandMeasure MeasureProfile "Update"][!CommandMeasure MeasureRank "Update"]
MouseOverAction=[!SetOption MeterRefresh FontColor #AccentColor#][!UpdateMeter MeterRefresh][!Redraw]
MouseLeaveAction=[!SetOption MeterRefresh FontColor #DimColor#][!UpdateMeter MeterRefresh][!Redraw]

[MeterEdit]
Meter=String
MeterStyle=StyleDim
StringAlign=Right
X=(#SkinWidth#-44)
Y=50
Text=EDIT
LeftMouseUpAction=["notepad.exe" "#@#Variables.inc"]
MouseOverAction=[!SetOption MeterEdit FontColor #AccentColor#][!UpdateMeter MeterEdit][!Redraw]
MouseLeaveAction=[!SetOption MeterEdit FontColor #DimColor#][!UpdateMeter MeterEdit][!Redraw]

; -- options: clear cached art / sign out --------------------------

[MeterCache]
Meter=String
MeterStyle=StyleDim
StringAlign=Right
X=(#SkinWidth#-88)
Y=50
Text=CLEAR CACHE
LeftMouseUpAction=["#@#ClearCache.bat"][!Refresh]
ToolTipText=Delete the downloaded badge images. They are re-fetched as needed, so this is safe.
MouseOverAction=[!SetOption MeterCache FontColor #AccentColor#][!UpdateMeter MeterCache][!Redraw]
MouseLeaveAction=[!SetOption MeterCache FontColor #DimColor#][!UpdateMeter MeterCache][!Redraw]

[MeterLogout]
Meter=String
MeterStyle=StyleDim
StringAlign=Right
X=(#SkinWidth#-160)
Y=50
Text=LOG OUT
LeftMouseUpAction=[!CommandMeasure MeasureScript "Logout()"]
ToolTipText=Removes your username and API key from this PC and returns to the setup screen. You will need to paste your Web API key again to sign back in.
MouseOverAction=[!SetOption MeterLogout FontColor #AccentColor#][!UpdateMeter MeterLogout][!Redraw]
MouseLeaveAction=[!SetOption MeterLogout FontColor #DimColor#][!UpdateMeter MeterLogout][!Redraw]

; -- status -------------------------------------------------------

[MeterStatus]
Meter=String
MeterStyle=StyleDim
FontSize=9
X=16
Y=80
Text=Loading...

